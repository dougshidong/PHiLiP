# Listing of Parameters
# ---------------------
 
# Solver dim and run type
set dimension = 3
set run_type = flow_simulation
 
# DG related parameters
set overintegration = 0
set use_weak_form = false
set flux_nodes_type = GLL
set use_split_form = true
set use_curvilinear_split_form = false
set use_weight_adjusted_mass = true
set all_boundaries_are_periodic = false
set check_same_coords_in_weak_dg = false
set flux_reconstruction = cDG
set flux_reconstruction_aux = kDG
set use_inverse_mass_on_the_fly = true
set do_renumber_dofs = false 
# PDE
set pde_type = navier_stokes
# set model_type = large_eddy_simulation

# numerical fluxes
set two_point_num_flux_type = Ra
set conv_num_flux = two_point_flux_with_l2roe_dissipation
set diss_num_flux = symm_internal_penalty
 
# additional parameters
# set solution_vtk_files_directory_name = solution_files
set output_high_order_grid = false
set enable_higher_order_vtk_output = true
set output_face_results_vtk = true

# ODE solver
subsection ODE solver
  set ode_output = quiet
  set ode_solver_type = runge_kutta
  set output_solution_every_dt_time_intervals = 1.0
  set output_solution_at_fixed_times = false
  set runge_kutta_method = ssprk3_ex
end

# ----------------------------------------
# - References for flow variables:
# - (1) Galbraith et Visbal. 
# - (2) Garmann et al.
# ----------------------------------------

# freestream Mach number
subsection euler
  set reference_length = 1.0
  set mach_infinity = 0.1
  set gamma_gas = 1.4
  set angle_of_attack = 8.0
end

# freestream Reynolds number and Prandtl number
subsection navier_stokes
  set prandtl_number = 0.72
  set reynolds_number_inf = 60000.0
  set temperature_inf = 273.15
  set thermal_boundary_condition_type = adiabatic
  # set nondimensionalized_isothermal_wall_temperature = 1.002
  set use_constant_viscosity = false
  set nondimensionalized_constant_viscosity = 1.0
end

# Physics Model (if pde_type == physics_model)
subsection physics_model
  set euler_turbulence = false
  subsection large_eddy_simulation
    set SGS_model_type = smagorinsky
    set turbulent_prandtl_number = 0.6
    set smagorinsky_model_constant = 0.1
    set WALE_model_constant = 0.1
    set vreman_model_constant = 0.1
    set ratio_of_filter_width_to_cell_size = 1.0
    # set poly_degree_max_large_scales = 3
  end
end

subsection flow_solver
  set flow_case_type = turbulent_airfoil_3D
  set steady_state = false
  set poly_degree = 3
  set final_time = 30.0
  set constant_time_step = 4.4E-5
  set adaptive_time_step = false
  set do_compute_unsteady_data_and_write_to_table = false
  # set unsteady_data_table_filename = sd7003_unsteady_data_table
  # set write_unsteady_data_table_file_every_dt_time_intervals = 1.0
  set output_restart_files = true
  set restart_files_directory_name = restart
  set output_restart_files_every_dt_time_intervals = 1.0
  subsection output_velocity_field
   set output_velocity_field_at_fixed_times = false
   set do_compute_time_averaged_solution = true
   set time_to_start_averaging = 20.0
   set do_compute_Reynolds_stress = true
   set time_to_start_computing_Reynolds_stress = 30.0E-5
  end
  subsection grid
    set use_gmsh_mesh = true
    set input_mesh_filename = /home/nyaki/Codes_2/PHiLiP/tests/meshes/SD7003_3rd_Order_4_Cell_Span
    subsection gmsh_boundary_IDs
      set use_periodic_BC_in_x = false
      set use_periodic_BC_in_y = false
      set use_periodic_BC_in_z = true
      # set x_periodic_id_face_1 = 2001
      # set x_periodic_id_face_2 = 2002
      # set y_periodic_id_face_1 = 2003
      # set y_periodic_id_face_2 = 2004
      set z_periodic_id_face_1 = 2005
      set z_periodic_id_face_2 = 2006
    end
  end
end
