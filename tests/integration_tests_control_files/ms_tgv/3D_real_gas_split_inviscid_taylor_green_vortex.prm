# Listing of Parameters
# ---------------------

# Reference:
# Will Trojak and Tarik Dzanic. Positivity-preserving discontinuous spectral element methods for compressible multi-species flows. Computers & Fluids, page 106343, 2024.

# Number of dimensions
set dimension = 3

# Number of chemical species
set number_of_species = 2

# Test set up
set pde_type = real_gas
set test_type = real_gas_split_taylor_green
set chemistry_input_file = ../../chemistry_files/O2_N2.kinetics

# DG formulation
set use_weak_form = false
set flux_nodes_type = GLL
set do_renumber_dofs = false
set use_split_form = true
set conv_num_flux = two_point_flux
set two_point_num_flux_type = KG
set flux_reconstruction = cDG
set use_inverse_mass_on_the_fly = true
set use_weight_adjusted_mass = true

set use_energy = true
set energy_file = ms-tgv-kg

set all_boundaries_are_periodic = true
set check_same_coords_in_weak_dg = false

set enable_higher_order_vtk_output = true

#limiter flags
subsection limiter
  set bound_preserving_limiter = positivity_preservingWang2012
  set min_density = 1e-13
end

subsection ODE solver
  set ode_output = verbose
  set nonlinear_max_iterations = 500
  set print_iteration_modulo = 100
  set ode_solver_type = runge_kutta
  set initial_time_step = 0.001
  set runge_kutta_method = ssprk3_ex
end

# freestream Mach number
subsection euler
  set mach_infinity = 0.1
end

subsection flow_solver
    set flow_case_type = multi_species_taylor_green_vortex_smooth
    #set apply_initial_condition_method = project_initial_condition_function
    set poly_degree = 3
    set final_time = 14.0
    subsection grid
        set number_of_grid_elements_per_dimension = 2
        set grid_left_bound = 0
        set grid_right_bound = 6.283185307179586476
        subsection grid_rectangle
          set grid_bottom_bound = 0
          set grid_top_bound = 6.283185307179586476
          set grid_z_lower_bound = 0
          set grid_z_upper_bound = 6.283185307179586476
          set number_of_grid_elements_x = 4
          set number_of_grid_elements_y = 4
          set number_of_grid_elements_z = 4
        end
    end
end

